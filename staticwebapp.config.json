{
  "routes": [
    {
      "route": "/api/user-trips",
      "methods": ["GET"],
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/api/user-trips/*",
      "methods": ["PUT", "DELETE"],
      "allowedRoles": ["owner"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/assets/*"]
  },
  "responseOverrides": {
    "401": {
      "statusCode": 401
    }
  }
}
